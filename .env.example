# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# All variables share the ATLAS_ prefix and map to fields on the Settings
# model in app/config.py. Real environment variables (set by Docker
# Compose, systemd, your platform, etc.) always take precedence over this
# file — .env is a development convenience, not a production secrets
# store. Adding a new Settings field? Add it here too, with a comment.

# SQLAlchemy async connection string. Defaults to a local SQLite file.
# The app is designed to be portable to PostgreSQL (see
# docs/adr/0002-async-ddd-monolith.md) — swap this for an async
# PostgreSQL DSN once a Postgres driver (e.g. asyncpg) is added.
ATLAS_DATABASE_URL=sqlite+aiosqlite:///./atlas.db

# Echo every SQL statement SQLAlchemy executes to stdout. Useful when
# debugging queries locally; leave off elsewhere — it's noisy.
ATLAS_DB_ECHO=false

# Linear personal API key for the Linear connector (create one in Linear
# under Settings > Security & access > Personal API keys). Leave empty to
# keep the connector disabled — the Connectors page will show
# "Not configured" and sync requests return 409.
ATLAS_LINEAR_API_KEY=

# OpenRouter API key for the AI Advisor (create one at
# https://openrouter.ai/keys). Leave empty to keep the advisor disabled —
# the Advisor page will show "Not configured" and advice requests return 409.
ATLAS_OPENROUTER_API_KEY=

# OpenRouter model slug the advisor uses (catalog: https://openrouter.ai/models).
# Pick a model that supports structured outputs.
ATLAS_ADVISOR_MODEL=anthropic/claude-sonnet-5

# Run a draft -> critique -> revise loop inside every advice request for
# higher-quality recommendations, at roughly 3x the LLM cost and latency
# per call. Leave false unless advice quality is worth the spend.
ATLAS_ADVISOR_SELF_CRITIQUE=false

# Secret URL token for MCP chat access (Claude / ChatGPT connectors).
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(24))"
# The MCP endpoint is served at /mcp/<token>/ — anyone with the full URL can
# read delivery data, so treat it like a password. Leave empty to disable
# (no MCP route is mounted at all).
ATLAS_MCP_TOKEN=
